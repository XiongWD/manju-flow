import { useEffect, useState, useCallback } from 'react'
import { useParams } from 'react-router-dom'
import { Badge } from '@/components/ui/badge'
import { Button } from '@/components/ui/button'
import { Card, CardContent } from '@/components/ui/card'
import { Skeleton } from '@/components/ui/skeleton'
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from '@/components/ui/table'
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs'
import { Input } from '@/components/ui/input'
import {
  Search,
  RefreshCw,
  Image,
  Video,
  Music,
  FileText,
  ShieldCheck,
  Eye,
  FolderKanban,
  Lock,
} from 'lucide-react'
import { episodeApi, assetApi, sceneApi, seedApi } from '@/lib/api'
import type { Episode, Scene, SceneVersion, Asset } from '@/types'
import { useNavigate } from 'react-router-dom'

const ASSET_TYPE_CONFIG: Record<string, { label: string; icon: typeof Image; color: string }> = {
  character_ref: { label: '角色参考', icon: Image, color: '#7C3AED' },
  scene_bg: { label: '场景背景', icon: Image, color: '#0891B2' },
  image: { label: '图像', icon: Image, color: '#7C3AED' },
  video: { label: '视频', icon: Video, color: '#F59E0B' },
  audio: { label: '音频', icon: Music, color: '#22C55E' },
  mixed_audio: { label: '混音', icon: Music, color: '#06B6D4' },
  qa_evidence: { label: 'QA 证据', icon: ShieldCheck, color: '#EF4444' },
  subtitle: { label: '字幕', icon: FileText, color: '#767D88' },
  cover: { label: '封面', icon: Image, color: '#F472B6' },
  rules_report: { label: '规则报告', icon: FileText, color: '#F97316' },
}

const SV_STATUS_CONFIG: Record<string, { label: string; color: string }> = {
  GENERATING: { label: '生成中', color: '#F59E0B' },
  QA_PASSED: { label: '质检通过', color: '#22C55E' },
  NEEDS_REVIEW: { label: '待审核', color: '#F97316' },
  MANUAL_APPROVED: { label: '人工通过', color: '#22C55E' },
  LOCKED: { label: '已锁定', color: '#7C3AED' },
  DELIVERED: { label: '已交付', color: '#06B6D4' },
}

export default function AssetBrowser() {
  const navigate = useNavigate()
  const { id: projectId } = useParams()
  const [episodes, setEpisodes] = useState<Episode[]>([])
  const [selectedEpisodeId, setSelectedEpisodeId] = useState<string | null>(null)
  const [scenes, setScenes] = useState<Scene[]>([])
  const [selectedSceneId, setSelectedSceneId] = useState<string | null>(null)
  const [versions, setVersions] = useState<SceneVersion[]>([])
  const [selectedVersionId, setSelectedVersionId] = useState<string | null>(null)
  const [assets, setAssets] = useState<Asset[]>([])
  const [loading, setLoading] = useState(true)
  const [search, setSearch] = useState('')
  const [assetTypeFilter, setAssetTypeFilter] = useState<string>('all')

  const fetchEpisodes = useCallback(async () => {
    if (!projectId) return
    try {
      const data = await episodeApi.list(projectId)
      setEpisodes(data)
      if (data.length > 0 && !selectedEpisodeId) {
        setSelectedEpisodeId(data[0].id)
      }
    } catch {}
  }, [projectId, selectedEpisodeId])

  const fetchScenes = useCallback(async () => {
    if (!selectedEpisodeId) return
    try {
      const data = await sceneApi.list(selectedEpisodeId)
      setScenes(data)
      if (data.length > 0 && !selectedSceneId) {
        setSelectedSceneId(data[0].id)
      }
    } catch {}
  }, [selectedEpisodeId, selectedSceneId])

  const fetchVersions = useCallback(async () => {
    if (!selectedSceneId) return
    try {
      const data = await sceneApi.versions(selectedSceneId)
      setVersions(data)
      // 自动选中最新版本
      if (data.length > 0) {
        const latest = data[data.length - 1]
        setSelectedVersionId(latest.id)
      } else {
        setSelectedVersionId(null)
      }
    } catch {}
  }, [selectedSceneId])

  const fetchAssets = useCallback(async () => {
    if (!projectId || !selectedVersionId) {
      setAssets([])
      return
    }
    try {
      const data = await assetApi.list({
        project_id: projectId,
        owner_type: 'scene_version',
        owner_id: selectedVersionId,
      })
      setAssets(data)
    } catch {}
  }, [projectId, selectedVersionId])

  useEffect(() => {
    const load = async () => {
      setLoading(true)
      await fetchEpisodes()
      setLoading(false)
    }
    load()
  }, [fetchEpisodes])

  useEffect(() => {
    fetchScenes()
  }, [fetchScenes])

  useEffect(() => {
    fetchVersions()
  }, [fetchVersions])

  useEffect(() => {
    fetchAssets()
  }, [fetchAssets])

  const handleSeedDemo = async () => {
    try {
      const result = await seedApi.demo()
      navigate(`/projects/${result.project_id}`)
    } catch {}
  }

  const filteredAssets = assets.filter((a) => {
    if (assetTypeFilter !== 'all' && a.type !== assetTypeFilter) return false
    if (search) {
      const q = search.toLowerCase()
      return (
        a.type.toLowerCase().includes(q) ||
        (a.metadata_json?.step as string)?.toLowerCase().includes(q) ||
        a.id.toLowerCase().includes(q)
      )
    }
    return true
  })

  const uniqueTypes = [...new Set(assets.map((a) => a.type))]

  return (
    <div className="space-y-8">
      {/* ── 页面标题 ── */}
      <div className="animate-in">
        <div className="section-kicker mb-3">Asset Browser</div>
        <div className="flex items-end justify-between">
          <h1 className="display-page text-white">素材库</h1>
          {!projectId && (
            <Button onClick={handleSeedDemo} className="bg-primary text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-primary/90 transition-colors duration-200">
              <FolderKanban className="mr-2 h-4 w-4" />
              生成演示数据
            </Button>
          )}
        </div>
      </div>

      {!projectId ? (
        <Card className="border-white/[0.06] bg-[#141416]">
          <CardContent className="flex flex-col items-center justify-center py-16">
            <Image className="mb-4 h-12 w-12 text-muted-foreground/40" />
            <h3 className="text-lg font-semibold text-white">请先选择项目</h3>
            <p className="mt-2 text-sm text-[#767D88] max-w-md text-center">
              从项目列表进入，或点击上方按钮生成演示数据。
            </p>
          </CardContent>
        </Card>
      ) : loading ? (
        <div className="space-y-4">
          <Skeleton className="h-16 w-full rounded-lg" />
          <Skeleton className="h-64 w-full rounded-lg" />
        </div>
      ) : (
        <>
          {/* ── 导航面包屑：集 → 场景 → 版本 ── */}
          <div className="flex flex-wrap items-center gap-3 animate-in animate-in-delay-1">
            {/* 集选择 */}
            {episodes.length > 0 && (
              <div className="flex items-center gap-1.5">
                <span className="text-xs text-[#767D88]">集</span>
                <div className="flex items-center gap-1">
                  {episodes.map((ep) => (
                    <button
                      key={ep.id}
                      onClick={() => { setSelectedEpisodeId(ep.id); setSelectedSceneId(null); setVersions([]); setAssets([]) }}
                      className={`rounded px-2.5 py-1 text-xs font-medium transition-all duration-200 ${
                        selectedEpisodeId === ep.id
                          ? 'bg-white/[0.08] text-white border border-white/[0.1]'
                          : 'text-[#767D88] hover:text-white/60'
                      }`}
                    >
                      E{ep.episode_no}
                    </button>
                  ))}
                </div>
              </div>
            )}

            {scenes.length > 0 && (
              <>
                <span className="text-white/10">/</span>
                <div className="flex items-center gap-1.5">
                  <span className="text-xs text-[#767D88]">场景</span>
                  <div className="flex items-center gap-1">
                    {scenes.map((s) => (
                      <button
                        key={s.id}
                        onClick={() => { setSelectedSceneId(s.id); setVersions([]); setAssets([]) }}
                        className={`rounded px-2.5 py-1 text-xs font-medium transition-all duration-200 ${
                          selectedSceneId === s.id
                            ? 'bg-white/[0.08] text-white border border-white/[0.1]'
                            : 'text-[#767D88] hover:text-white/60'
                        }`}
                      >
                        S{String(s.scene_no).padStart(2, '0')}
                      </button>
                    ))}
                  </div>
                </div>
              </>
            )}

            {versions.length > 0 && (
              <>
                <span className="text-white/10">/</span>
                <div className="flex items-center gap-1.5">
                  <span className="text-xs text-[#767D88]">版本</span>
                  <div className="flex items-center gap-1">
                    {versions.map((v) => {
                      const sc = SV_STATUS_CONFIG[v.status] || { color: '#767D88' }
                      const isLocked = scenes.find((s) => s.id === selectedSceneId)?.locked_version_id === v.id
                      return (
                        <button
                          key={v.id}
                          onClick={() => setSelectedVersionId(v.id)}
                          className={`rounded px-2.5 py-1 text-xs font-mono font-medium transition-all duration-200 flex items-center gap-1.5 ${
                            selectedVersionId === v.id
                              ? 'bg-white/[0.08] text-white border border-white/[0.1]'
                              : 'text-[#767D88] hover:text-white/60'
                          }`}
                        >
                          {isLocked && <Lock className="h-2.5 w-2.5 text-purple-400" />}
                          v{v.version_no}
                          <span className="inline-block h-1 w-1 rounded-full" style={{ backgroundColor: sc.color }} />
                        </button>
                      )
                    })
                  </div>
                </div>
              </>
            )}
          </div>

          {/* ── 筛选栏 ── */}
          {selectedVersionId && (
            <div className="flex items-center gap-3 animate-in animate-in-delay-2">
              <div className="relative flex-1 max-w-xs">
                <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[#767D88]" />
                <Input
                  placeholder="搜索资产..."
                  value={search}
                  onChange={(e) => setSearch(e.target.value)}
                  className="pl-9 bg-white/[0.03] border-white/[0.06] text-white text-sm placeholder:text-[#767D88] focus:border-primary/50 rounded-lg h-9"
                />
              </div>
              <div className="flex items-center gap-1 flex-wrap">
                <button
                  onClick={() => setAssetTypeFilter('all')}
                  className={`rounded px-2.5 py-1 text-xs font-medium transition-all duration-200 ${
                    assetTypeFilter === 'all' ? 'bg-white/[0.08] text-white' : 'text-[#767D88] hover:text-white/60'
                  }`}
                >
                  全部
                </button>
                {uniqueTypes.map((t) => {
                  const cfg = ASSET_TYPE_CONFIG[t]
                  return (
                    <button
                      key={t}
                      onClick={() => setAssetTypeFilter(t)}
                      className={`rounded px-2.5 py-1 text-xs font-medium transition-all duration-200 ${
                        assetTypeFilter === t ? 'bg-white/[0.08] text-white' : 'text-[#767D88] hover:text-white/60'
                      }`}
                    >
                      {cfg?.label || t}
                    </button>
                  )
                })}
              </div>
              <span className="meta-ui ml-auto">{filteredAssets.length} 项</span>
            </div>
          )}

          {/* ── 资产列表 ── */}
          {selectedVersionId ? (
            filteredAssets.length === 0 ? (
              <Card className="border-white/[0.06] bg-[#141416]">
                <CardContent className="flex flex-col items-center justify-center py-12">
                  <Eye className="mb-3 h-8 w-8 text-muted-foreground/30" />
                  <p className="text-sm text-[#767D88]">
                    {assets.length === 0 ? '该版本暂无关联资产' : '无匹配结果'}
                  </p>
                </CardContent>
              </Card>
            ) : (
              <div className="rounded-lg border border-white/[0.06] bg-[#141416] overflow-hidden animate-in animate-in-delay-3">
                <Table>
                  <TableHeader>
                    <TableRow className="border-white/[0.06] hover:bg-transparent">
                      <TableHead className="text-[#767D88] text-xs font-medium uppercase tracking-wider">类型</TableHead>
                      <TableHead className="text-[#767D88] text-xs font-medium uppercase tracking-wider">来源步骤</TableHead>
                      <TableHead className="text-[#767D88] text-xs font-medium uppercase tracking-wider">URI</TableHead>
                      <TableHead className="text-[#767D88] text-xs font-medium uppercase tracking-wider">大小</TableHead>
                      <TableHead className="text-[#767D88] text-xs font-medium uppercase tracking-wider">上下文</TableHead>
                      <TableHead className="text-[#767D88] text-xs font-medium uppercase tracking-wider">创建时间</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {filteredAssets.map((asset) => {
                      const cfg = ASSET_TYPE_CONFIG[asset.type]
                      const Icon = cfg?.icon || FileText
                      const ownerContext = (asset.metadata_json?.source as string) || (asset.metadata_json?.step as string) || '—'
                      return (
                        <TableRow key={asset.id} className="border-white/[0.04] hover:bg-white/[0.02]">
                          <TableCell>
                            <div className="flex items-center gap-2">
                              <Icon className="h-4 w-4" style={{ color: cfg?.color || '#767D88' }} />
                              <span className="text-sm text-white">{cfg?.label || asset.type}</span>
                            </div>
                          </TableCell>
                          <TableCell className="text-xs text-[#767D88] font-mono">
                            {(asset.metadata_json?.step as string) || '—'}
                          </TableCell>
                          <TableCell className="text-xs text-white/40 font-mono max-w-[200px] truncate">
                            {asset.uri || '—'}
                          </TableCell>
                          <TableCell className="text-xs text-[#767D88]">
                            {asset.file_size ? `${(asset.file_size / 1024).toFixed(1)} KB` : '—'}
                          </TableCell>
                          <TableCell className="text-xs text-[#767D88] max-w-[120px] truncate">
                            {ownerContext}
                          </TableCell>
                          <TableCell className="text-xs text-[#767D88]">
                            {asset.created_at ? new Date(asset.created_at).toLocaleString('zh-CN') : '—'}
                          </TableCell>
                        </TableRow>
                      )
                    })
                  </TableBody>
                </Table>
              </div>
            )
          ) : (
            <Card className="border-white/[0.06] bg-[#141416]">
              <CardContent className="flex flex-col items-center justify-center py-12">
                <Eye className="mb-3 h-8 w-8 text-muted-foreground/30" />
                <p className="text-sm text-[#767D88]">选择场景版本以查看关联资产</p>
              </CardContent>
            </Card>
          )}
        </>
      )}
    </div>
  )
}

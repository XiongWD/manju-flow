# =============================================================================
# Manju Production OS — 环境变量模板
# 复制为 .env 后填入实际值：cp .env.example .env
# =============================================================================

# ── 通用 ─────────────────────────────────────────────────────────────────────
# 项目名称（用于日志前缀、DB 表前缀等）
MANJU_APP_NAME=ManjuProductionOS
# 运行环境：development | staging | production
MANJU_ENV=development
# 日志级别：DEBUG | INFO | WARNING | ERROR
MANJU_LOG_LEVEL=INFO

# ── 数据库 ───────────────────────────────────────────────────────────────────
# SQLite（默认）
DATABASE_URL=sqlite+aiosqlite:///./manju.db
# PostgreSQL（迁移时切换，取消注释即可）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/manju

# ── 后端服务 ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── 视频生成 API Keys ──────────────────────────────────────────────────────
# Kling 3.0（可灵 AI）
KLING_API_KEY=
KLING_API_BASE=https://api.klingai.com

# Seedance 2.0（即梦 AI）
SEEDANCE_API_KEY=
SEEDANCE_API_BASE=https://api.seedance.com

# ── 语音合成 API Keys ──────────────────────────────────────────────────────
# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE=https://api.elevenlabs.io

# Fish Audio
FISH_AUDIO_API_KEY=
FISH_AUDIO_API_BASE=https://api.fish.audio

# ── ComfyUI（远程 GPU） ────────────────────────────────────────────────────
# Vast.ai 实例信息
VAST_API_KEY=
# ComfyUI 服务地址（Vast.ai 实例的公网 IP + 端口）
COMFYUI_HOST=
COMFYUI_PORT=8188
# ComfyUI 完整 API 地址（优先使用，若设置则忽略 HOST/PORT）
COMFYUI_API_URL=

# ── C2PA 内容凭证 ──────────────────────────────────────────────────────────
# c2patool 路径（留空则从 PATH 查找）
C2PATOOL_PATH=
# 签名密钥路径（可选）
C2PA_SIGNING_KEY_PATH=

# ── 文件存储 ────────────────────────────────────────────────────────────────
# 上传文件存储根目录
STORAGE_ROOT=./storage
# 输出文件存储目录
OUTPUT_DIR=./storage/output
